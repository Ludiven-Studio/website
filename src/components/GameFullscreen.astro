---
// Adds a "Plein écran" button to every game page. Fullscreen shows ONLY the game
// window (page chrome hidden) with a "⛶ Quitter" button anchored inside it.
// Layout is driven by a CLASS (`gf-full` on `.game-page`), not the `:fullscreen`
// pseudo-class, so it works even where the Fullscreen API is missing (iOS Safari):
// there we fall back to a fixed full-viewport overlay. The native API is still
// requested best-effort (desktop/Android) to hide the browser chrome.
// Rendered once by BaseLayout, on game pages only.
---

<style is:global>
	.gf-btn {
		border: 1.5px solid var(--gray-700);
		background: transparent;
		color: var(--gray-300);
		font-family: var(--font-brand);
		font-weight: 500;
		font-size: var(--text-sm);
		border-radius: 999px;
		padding: 5px 14px;
		cursor: pointer;
		margin-top: 0.25rem;
		transition:
			color var(--theme-transition),
			border-color var(--theme-transition);
	}
	.gf-btn:hover,
	.gf-btn:focus-visible {
		color: var(--accent-regular);
		border-color: var(--accent-regular);
	}

	/* Exit button anchored inside the game area — only visible in fullscreen.
	   Insets respect the notch/home-bar (needs viewport-fit=cover). */
	.gf-exit {
		position: fixed;
		top: max(12px, env(safe-area-inset-top));
		right: max(12px, env(safe-area-inset-right));
		z-index: 2147483647;
		display: none;
		border: 1.5px solid var(--gray-600);
		background: var(--gray-900);
		color: var(--gray-0);
		font-family: var(--font-brand);
		font-weight: 600;
		font-size: var(--text-sm);
		border-radius: 999px;
		padding: 7px 14px;
		cursor: pointer;
		box-shadow: var(--shadow-md);
	}

	/* Fullscreen fill, driven by the class (works with OR without the native API).
	   Fills the viewport, hides page chrome, keeps only the game + its controls.
	   Centering must be SAFE: with plain `center`, content taller than the screen
	   (mobile landscape) overflows upward and the top becomes unreachable. */
	.game-page.gf-full {
		position: fixed;
		inset: 0;
		z-index: 40;
		max-width: none;
		width: 100%;
		height: 100%;
		background: var(--gray-999);
		overflow: auto;
		padding:
			max(1rem, env(safe-area-inset-top))
			max(1rem, env(safe-area-inset-right))
			max(1rem, env(safe-area-inset-bottom))
			max(1rem, env(safe-area-inset-left));
		justify-content: flex-start;
	}
	@supports (justify-content: safe center) {
		.game-page.gf-full {
			justify-content: safe center;
		}
	}
	/* Lock the page behind the overlay from scrolling. */
	html.gf-full,
	html.gf-full body {
		overflow: hidden;
	}
	/* Pseudo-fullscreen (iOS / no native API): the overlay covers the viewport but the
	   site nav & footer are still in the DOM — hide them so they can't catch taps. */
	html.gf-full .backgrounds > nav,
	html.gf-full .backgrounds > footer {
		display: none;
	}
	.game-page.gf-full > .game-head {
		display: none;
	}
	.game-page.gf-full .gf-exit {
		display: block;
	}
</style>

<script>
	(() => {
		const d = document as any;
		const html = document.documentElement;
		const host = document.querySelector('.game-head');
		const target = document.querySelector('.game-page') as any;
		if (!host || !target) return;

		const nativeFsEl = (): Element | null => d.fullscreenElement || d.webkitFullscreenElement || null;
		let on = false; // our own state (native API may be absent — iOS)
		let synthetic = false; // guards our self-dispatched re-measure ping

		const setLabel = (): void => {
			btn.textContent = on ? '⛶ Quitter le plein écran' : '⛶ Plein écran';
		};
		// Let games re-measure their canvas: they already listen to `fullscreenchange`,
		// which the native API doesn't fire on iOS — so dispatch it ourselves.
		const notify = (): void => {
			requestAnimationFrame(() => {
				synthetic = true;
				document.dispatchEvent(new Event('fullscreenchange'));
				synthetic = false;
			});
		};

		const enter = (): void => {
			on = true;
			target.classList.add('gf-full');
			html.classList.add('gf-full');
			try {
				if (target.requestFullscreen) void target.requestFullscreen().catch(() => {});
				else if (target.webkitRequestFullscreen) target.webkitRequestFullscreen();
			} catch {
				/* iOS / denied — the class-based overlay already fills the screen */
			}
			setLabel();
			notify();
		};
		const exit = (): void => {
			on = false;
			target.classList.remove('gf-full');
			html.classList.remove('gf-full');
			try {
				if (nativeFsEl()) {
					if (d.exitFullscreen) void d.exitFullscreen().catch(() => {});
					else if (d.webkitExitFullscreen) d.webkitExitFullscreen();
				}
			} catch {
				/* ignore */
			}
			setLabel();
			notify();
		};
		const toggle = (): void => (on ? exit() : enter());

		// Enter button in the header.
		const btn = document.createElement('button');
		btn.type = 'button';
		btn.className = 'gf-btn';
		btn.textContent = '⛶ Plein écran';
		btn.addEventListener('click', toggle);
		host.appendChild(btn);

		// Exit button anchored inside the game area (shown only in fullscreen).
		const exitBtn = document.createElement('button');
		exitBtn.type = 'button';
		exitBtn.className = 'gf-exit';
		exitBtn.textContent = '⛶ Quitter';
		exitBtn.addEventListener('click', toggle);
		target.appendChild(exitBtn);

		// Keep state in sync if the user exits native fullscreen via Esc / system UI.
		// Ignore our own synthetic re-measure ping (guarded by `synthetic`).
		const onNativeChange = (): void => {
			if (synthetic) return;
			if (on && !nativeFsEl()) exit(); // native fullscreen ended → tear our overlay down too
			setLabel();
		};
		document.addEventListener('fullscreenchange', onNativeChange);
		document.addEventListener('webkitfullscreenchange', onNativeChange as EventListener);
		// Esc key in the pseudo-fullscreen (iOS/no-API) case.
		document.addEventListener('keydown', (e) => {
			if (on && e.key === 'Escape' && !nativeFsEl()) exit();
		});
	})();
</script>
