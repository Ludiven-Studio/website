---
// Adds a "Plein écran" button to every game page. Fullscreen shows ONLY the game
// window (the page chrome/header is hidden), and an "⛶ Quitter" button is anchored
// inside the game area (the header — with the enter button — is hidden then).
// On touch devices it also tries to lock landscape. Rendered once by BaseLayout.
---

<style is:global>
	.gf-btn {
		border: 1.5px solid var(--gray-700);
		background: transparent;
		color: var(--gray-300);
		font-family: var(--font-brand);
		font-weight: 500;
		font-size: var(--text-sm);
		border-radius: 999px;
		padding: 5px 14px;
		cursor: pointer;
		margin-top: 0.25rem;
		transition:
			color var(--theme-transition),
			border-color var(--theme-transition);
	}
	.gf-btn:hover,
	.gf-btn:focus-visible {
		color: var(--accent-regular);
		border-color: var(--accent-regular);
	}

	/* Exit button anchored inside the game area — only visible in fullscreen. */
	.gf-exit {
		position: fixed;
		top: 12px;
		right: 12px;
		z-index: 2147483647;
		display: none;
		border: 1.5px solid var(--gray-600);
		background: var(--gray-900);
		color: var(--gray-0);
		font-family: var(--font-brand);
		font-weight: 600;
		font-size: var(--text-sm);
		border-radius: 999px;
		padding: 7px 14px;
		cursor: pointer;
		box-shadow: var(--shadow-md);
	}

	/* Fullscreen: fill the screen, hide page chrome, keep only the game + its controls. */
	.game-page:fullscreen {
		max-width: none;
		width: 100%;
		height: 100%;
		background: var(--gray-999);
		overflow: auto;
		padding: 1rem;
		justify-content: center;
	}
	.game-page:fullscreen > .game-head {
		display: none;
	}
	.game-page:fullscreen .gf-exit {
		display: block;
	}
	.game-page:-webkit-full-screen {
		max-width: none;
		width: 100%;
		height: 100%;
		background: var(--gray-999);
		overflow: auto;
		padding: 1rem;
		justify-content: center;
	}
	.game-page:-webkit-full-screen > .game-head {
		display: none;
	}
	.game-page:-webkit-full-screen .gf-exit {
		display: block;
	}
</style>

<script>
	(() => {
		const d = document as any;
		const rootEl = document.documentElement as any;
		if (!(rootEl.requestFullscreen || rootEl.webkitRequestFullscreen)) return; // unsupported (e.g. iOS Safari)

		const host = document.querySelector('.game-head');
		const target = document.querySelector('.game-page') as any;
		if (!host || !target) return;

		const fsEl = (): Element | null => d.fullscreenElement || d.webkitFullscreenElement || null;

		const lockLandscape = async (): Promise<void> => {
			if (!window.matchMedia('(pointer: coarse)').matches) return;
			const o = (screen as any).orientation;
			try {
				if (o && o.lock) await o.lock('landscape');
			} catch {
				/* not allowed — ignore */
			}
		};
		const enter = async (): Promise<void> => {
			try {
				if (target.requestFullscreen) await target.requestFullscreen();
				else if (target.webkitRequestFullscreen) target.webkitRequestFullscreen();
			} catch {
				/* ignore */
			}
			await lockLandscape();
		};
		const exit = async (): Promise<void> => {
			try {
				if (d.exitFullscreen) await d.exitFullscreen();
				else if (d.webkitExitFullscreen) d.webkitExitFullscreen();
			} catch {
				/* ignore */
			}
			const o = (screen as any).orientation;
			try {
				if (o && o.unlock) o.unlock();
			} catch {
				/* ignore */
			}
		};
		const toggle = (): void => {
			if (fsEl()) void exit();
			else void enter();
		};

		// Enter button in the header.
		const btn = document.createElement('button');
		btn.type = 'button';
		btn.className = 'gf-btn';
		btn.textContent = '⛶ Plein écran';
		btn.addEventListener('click', toggle);
		host.appendChild(btn);

		// Exit button anchored inside the game area (shown only in fullscreen).
		const exitBtn = document.createElement('button');
		exitBtn.type = 'button';
		exitBtn.className = 'gf-exit';
		exitBtn.textContent = '⛶ Quitter';
		exitBtn.addEventListener('click', toggle);
		target.appendChild(exitBtn);

		document.addEventListener('fullscreenchange', () => {
			btn.textContent = fsEl() ? '⛶ Quitter le plein écran' : '⛶ Plein écran';
		});
		document.addEventListener('webkitfullscreenchange', (() => {
			btn.textContent = fsEl() ? '⛶ Quitter le plein écran' : '⛶ Plein écran';
		}) as EventListener);
	})();
</script>
