---
import Icon from './Icon.astro';
import type { iconPaths } from './IconPaths';

interface Props {
	title: string;
	pitch: string;
	icon: keyof typeof iconPaths;
	href?: string;
	status?: 'play' | 'soon';
	id?: string;
	favorite?: boolean;
	image?: string;
	daily?: boolean; // false for games without a daily challenge (e.g. multiplayer)
	compact?: boolean; // drop the image + pitch → a small tile (used on the daily page)
}

const { title, pitch, icon, href, status = 'play', id, favorite = false, image, daily = true, compact = false } = Astro.props;
const playable = status === 'play' && href;
const Tag = playable ? 'a' : 'div';
const showFavorite = favorite && playable && id;
// Convention: a generated screenshot at /assets/jeux/<id>.jpg. onerror removes it if absent.
const media = image ?? (playable && id ? `/assets/jeux/${id}.jpg` : undefined);
---

<div class:list={['game-card-wrap', { 'has-fav': showFavorite }]} data-game-id={id}>
	<Tag
		class:list={['game-card', { soon: !playable }]}
		{...playable ? { href } : { 'aria-disabled': 'true' }}
	>
		{media && !compact && (
			<div class="game-card-media">
				<img src={media} alt="" loading="lazy" onerror="this.parentElement.remove()" />
			</div>
		)}
		<div class="game-card-top">
			<Icon icon={icon} color="var(--accent-regular)" size="2.5rem" gradient />
			<span class:list={['badge', { soon: !playable }]}>
				{playable ? 'Jouer' : 'Bientôt'}
			</span>
		</div>
		<h3>{title}</h3>
		{playable && id && daily && <span class="daily-chip" data-game-id={id} hidden />}
			{playable && id && daily && <span class="streak-badge" data-game-id={id} hidden />}
			{playable && id && <span class="level-badge" data-game-id={id} hidden />}
		{!compact && <p>{pitch}</p>}
	</Tag>
	{
		showFavorite && (
			<button
				type="button"
				class="fav-toggle"
				data-game-id={id}
				aria-pressed="false"
				aria-label={`Mettre ${title} en favori`}
			>
				<svg viewBox="0 0 256 256" width="22" height="22" aria-hidden="true">
					<path d="M128 216S28 160 28 92a52 52 0 0 1 100-20h0a52 52 0 0 1 100 20c0 68-100 124-100 124Z" />
				</svg>
			</button>
		)
	}
</div>

<style>
	.game-card-wrap {
		position: relative;
		height: 100%;
	}

	.game-card-wrap.has-fav .game-card {
		/* keep room so a long pitch never slides under the heart */
		padding-bottom: 3.25rem;
	}

	.fav-toggle {
		position: absolute;
		bottom: 1rem;
		right: 1rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.35rem;
		border: none;
		border-radius: 999rem;
		background: transparent;
		color: var(--gray-400);
		cursor: pointer;
		line-height: 0;
		transition:
			color var(--theme-transition),
			transform var(--theme-transition);
	}

	.fav-toggle svg {
		fill: none;
		stroke: currentColor;
		stroke-width: 18;
		stroke-linejoin: round;
	}

	.fav-toggle:hover,
	.fav-toggle:focus-visible {
		color: var(--accent-regular);
		transform: scale(1.12);
	}

	.fav-toggle.is-fav {
		color: var(--accent-regular);
	}

	.fav-toggle.is-fav svg {
		fill: currentColor;
	}

	.game-card {
		display: flex;
		flex-direction: column;
		height: 100%;
		gap: 0.75rem;
		border: 1px solid var(--gray-800);
		border-radius: 1.5rem;
		padding: 1.75rem;
		background-color: var(--gray-999_40);
		box-shadow: var(--shadow-sm);
		text-decoration: none;
		color: inherit;
		transition:
			transform var(--theme-transition),
			border-color var(--theme-transition),
			box-shadow var(--theme-transition);
	}

	a.game-card:hover,
	a.game-card:focus-visible {
		transform: translateY(-4px);
		border-color: var(--accent-regular);
		box-shadow: var(--shadow-md);
	}

	.game-card.soon {
		opacity: 0.55;
		cursor: default;
	}

	.game-card-media {
		border-radius: 0.75rem;
		overflow: hidden;
		aspect-ratio: 16 / 10;
		background: var(--gray-800);
	}

	.game-card-media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.game-card-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.badge {
		font-family: var(--font-brand);
		font-weight: 500;
		font-size: var(--text-sm);
		line-height: 1;
		padding: 0.4rem 0.85rem;
		border-radius: 999rem;
		color: var(--accent-text-over);
		background-color: var(--accent-regular);
		white-space: nowrap;
	}

	.badge.soon {
		color: var(--gray-300);
		background-color: transparent;
		border: 1px solid var(--gray-700);
	}

	.game-card h3 {
		font-size: var(--text-lg);
		margin: 0;
	}

	.daily-chip {
		align-self: flex-start;
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		font-family: var(--font-brand);
		font-weight: 500;
		font-size: var(--text-sm);
		line-height: 1;
		padding: 0.3rem 0.7rem;
		border-radius: 999rem;
		border: 1px solid var(--gray-700);
		color: var(--gray-300);
	}

	.daily-chip.progress {
		border-color: var(--accent-regular);
		color: var(--accent-regular);
	}

	.daily-chip.done {
		border-color: var(--accent-regular);
		background-color: var(--accent-regular);
		color: var(--accent-text-over);
	}

	.streak-badge {
		align-self: flex-start;
		display: inline-flex;
		align-items: center;
		gap: 3px;
		font-family: var(--font-brand);
		font-weight: 800;
		font-size: 12px;
		line-height: 1;
		padding: 3px 9px;
		border-radius: 999rem;
		color: #f5a623;
		background: rgba(245, 166, 35, 0.12);
		border: 1px solid rgba(245, 166, 35, 0.4);
	}

	.level-badge {
		align-self: flex-start;
		display: inline-flex;
		align-items: center;
		gap: 3px;
		font-family: var(--font-brand);
		font-weight: 700;
		font-size: 12px;
		line-height: 1;
		padding: 3px 9px;
		border-radius: 999rem;
		color: var(--accent-regular);
		background: var(--accent-overlay);
		border: 1px solid var(--accent-regular);
	}

	/* [hidden] must win over the display above, else empty badges show as blank pills. */
	.daily-chip[hidden],
	.streak-badge[hidden],
	.level-badge[hidden] {
		display: none;
	}

	.game-card p {
		color: var(--gray-400);
		margin: 0;
		font-size: var(--text-base);
	}

	@media (min-width: 50em) {
		.game-card h3 {
			font-size: var(--text-xl);
		}
	}
</style>

<script>
	import { fetchDailyTops, leaderboardEnabled } from '../lib/leaderboard';
	import { DAILY_LB } from '../data/dailyLb';
	import { formatScore } from '../lib/scoreFormat';
	import { gameStreak } from '../lib/streak';

	// Favorites toggle — persisted in localStorage, shared key with the home page.
	const KEY = 'ludiven-favorites';

	const read = (): string[] => {
		try {
			return JSON.parse(localStorage.getItem(KEY) || '[]');
		} catch {
			return [];
		}
	};

	const sync = () => {
		const favs = read();
		document.querySelectorAll<HTMLButtonElement>('.fav-toggle').forEach((btn) => {
			const on = favs.includes(btn.dataset.gameId || '');
			btn.classList.toggle('is-fav', on);
			btn.setAttribute('aria-pressed', String(on));
		});
	};

	document.addEventListener('click', (e) => {
		const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.fav-toggle');
		if (!btn) return;
		e.preventDefault();
		const id = btn.dataset.gameId;
		if (!id) return;
		const favs = read();
		const i = favs.indexOf(id);
		if (i >= 0) favs.splice(i, 1);
		else favs.push(id);
		localStorage.setItem(KEY, JSON.stringify(favs));
		sync();
	});

	sync();

	// Daily challenge status — same localStorage key as each game's daily run.
	const todayKey = () => {
		const d = new Date();
		return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
	};

	const syncDaily = () => {
		const day = todayKey();
		document.querySelectorAll<HTMLElement>('.daily-chip').forEach((chip) => {
			const id = chip.dataset.gameId;
			if (!id) return;
			let started = false;
			let done = false;
			try {
				const raw = localStorage.getItem(`ludiven-dailyrun-${id}-${day}`);
				if (raw) {
					started = true;
					done = JSON.parse(raw)?.done === true;
				}
			} catch {
				/* ignore */
			}
			// Player's best-of-day record (some games log it under `${id}-t`).
			let rec: { m?: string; t?: string } | null = null;
			try {
				const raw = localStorage.getItem(`ludiven-dayrec-${id}-${day}`) || localStorage.getItem(`ludiven-dayrec-${id}-t-${day}`);
				if (raw) rec = JSON.parse(raw);
			} catch {
				/* ignore */
			}
			const recTxt = rec?.t ? `${rec.t}${rec.m === 'score' ? ' pts' : ''}` : '';
			chip.classList.toggle('done', done);
			chip.classList.toggle('progress', started && !done);
			// Tag the card so pages (e.g. the daily page) can reorder / dim by status.
			const wrap = chip.closest('.game-card-wrap');
			wrap?.classList.toggle('daily-done', done);
			wrap?.classList.toggle('daily-todo', !done);
			wrap?.dispatchEvent(new CustomEvent('daily-status', { bubbles: true, detail: { id, done, started } }));
			// Community record of the day (Supabase), shown even for games not yet played.
			const cfg = DAILY_LB[id];
			const top = cfg ? tops[cfg.lbId || id] : undefined;
			if (top) {
				const nb = top.players || 0;
				chip.title = `Record du jour${nb ? ` · ${nb} participant${nb > 1 ? 's' : ''}` : ''}`;
				const val = formatScore(cfg!.fmt, top.value);
				const who = `${val ? `${val} · ` : ''}${top.name}`;
				chip.textContent = `${done ? '✓ ' : ''}🏆 ${who}${nb ? ` · ${nb} participant${nb > 1 ? 's' : ''}` : ''}`;
			} else {
				chip.textContent = done
					? recTxt
						? `✓ Record du jour : ${recTxt}`
						: '✓ Défi du jour fait'
					: started
						? recTxt
							? `⏳ En cours · ${recTxt}`
							: '⏳ Défi en cours'
						: '🏆 Défi du jour à faire';
			}
			chip.hidden = false;
		});
	};

	// Per-game daily streak badge (🔥 N consecutive days).
	const syncStreak = () => {
		document.querySelectorAll<HTMLElement>('.streak-badge').forEach((badge) => {
			const id = badge.dataset.gameId;
			if (!id) return;
			const s = gameStreak(id);
			if (s.count > 0) {
				badge.textContent = `🔥 ${s.count}`;
				badge.title = `${s.count} jour${s.count > 1 ? 's' : ''} d'affilée${s.atRisk ? ' · joue aujourd\'hui pour la garder' : ''}`;
				badge.hidden = false;
			} else {
				badge.hidden = true;
			}
		});
	};

	// Per-game levels progress badge (🎯 current level), read from the local progression
	// mirror. Hidden for games with no levels or no progress yet. (LEVEL_COUNT = 100.)
	const syncLevels = () => {
		document.querySelectorAll<HTMLElement>('.level-badge').forEach((badge) => {
			const id = badge.dataset.gameId;
			if (!id) return;
			let stars: Record<string, number> = {};
			try {
				const raw = localStorage.getItem(`ludiven-progress-${id}`);
				if (raw) stars = JSON.parse(raw)?.stars ?? {};
			} catch {
				/* ignore */
			}
			const cleared = Object.keys(stars).map(Number).filter((n) => stars[n] >= 1);
			if (cleared.length === 0) {
				// Not played yet → invite to start at level 1.
				badge.textContent = '🎯 Niveau 1';
				badge.title = 'Commence les niveaux';
				badge.hidden = false;
				return;
			}
			const maxCleared = Math.max(...cleared);
			if (maxCleared >= 100) {
				const total = cleared.reduce((a, n) => a + (stars[n] || 0), 0);
				badge.textContent = `🎯 Fini · ${total}★`;
			} else {
				badge.textContent = `🎯 Niveau ${maxCleared + 1}`;
			}
			badge.title = 'Ta progression en mode Niveaux';
			badge.hidden = false;
		});
	};

	// Community daily records (one Supabase request), then refresh the chips.
	let tops: Record<string, { name: string; value: number; players: number }> = {};
	const loadTops = async () => {
		if (!leaderboardEnabled()) return;
		try {
			tops = await fetchDailyTops();
		} catch {
			/* ignore */
		}
		syncDaily();
	};

	syncDaily();
	syncStreak();
	syncLevels();
	loadTops();
	// Refresh when returning to the page (tab focus, and back-nav restored from bfcache).
	document.addEventListener('visibilitychange', () => {
		if (!document.hidden) {
			syncDaily();
			syncStreak();
			syncLevels();
		}
	});
	window.addEventListener('pageshow', () => {
		syncDaily();
		syncStreak();
		syncLevels();
	});
</script>
