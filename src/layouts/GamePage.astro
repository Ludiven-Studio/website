---
import BaseLayout from './BaseLayout.astro';
import Icon from '../components/Icon.astro';
import GameTutorial from '../components/GameTutorial.astro';

interface Props {
	title: string;
	description: string;
	heading: string;
	tagline: string;
	gameId: string;
}

const { title, description, heading, tagline, gameId } = Astro.props;
---

<BaseLayout title={title} description={description}>
	<div class="wrapper game-page stack gap-8">
		<header class="game-head stack gap-2">
			<a class="back" href="/jeux/">
				<Icon icon="arrow-left" size="1em" /> Tous les jeux
			</a>
			<h1>{heading}</h1>
			<p>{tagline}</p>
			<GameTutorial gameId={gameId} />
		</header>

		<slot />
	</div>
</BaseLayout>

<style>
	.game-page {
		align-items: center;
	}
	.game-head {
		text-align: center;
		align-items: center;
	}
	.back {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		color: var(--gray-300);
		text-decoration: none;
		font-family: var(--font-brand);
		font-weight: 500;
		font-size: var(--text-sm);
	}
	.back:hover,
	.back:focus-visible {
		color: var(--accent-regular);
	}
	.game-head h1 {
		font-size: var(--text-3xl);
		margin-top: 0.5rem;
	}
	.game-head p {
		color: var(--gray-300);
	}
	@media (min-width: 50em) {
		.game-head h1 {
			font-size: var(--text-4xl);
		}
	}
</style>
