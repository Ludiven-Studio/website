---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import FlappyGame from '../../games/flappy/FlappyGame.tsx';
import GameTutorial from '../../components/GameTutorial.astro';
---

<BaseLayout
	title="Flappy Bird | Jeux Ludiven Studio"
	description="Flappy Bird : bats des ailes pour franchir un maximum de tuyaux. Défi du jour à tuyaux partagés et classement par score. Un jeu d'adresse signé Ludiven Studio."
>
	<div class="wrapper game-page stack gap-8">
		<header class="game-head stack gap-2">
			<a class="back" href="/jeux/">
				<Icon icon="arrow-left" size="1em" /> Tous les jeux
			</a>
			<h1>Flappy Bird</h1>
			<p>Bats des ailes, passe les tuyaux</p>
			<GameTutorial gameId="flappy" />
		</header>

		<FlappyGame client:only="react" gameId="flappy" />
	</div>
</BaseLayout>

<style>
	.game-page {
		align-items: center;
	}
	.game-head {
		text-align: center;
		align-items: center;
	}
	.back {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		color: var(--gray-300);
		text-decoration: none;
		font-family: var(--font-brand);
		font-weight: 500;
		font-size: var(--text-sm);
	}
	.back:hover,
	.back:focus-visible {
		color: var(--accent-regular);
	}
	.game-head h1 {
		font-size: var(--text-3xl);
		margin-top: 0.5rem;
	}
	.game-head p {
		color: var(--gray-300);
	}
	@media (min-width: 50em) {
		.game-head h1 {
			font-size: var(--text-4xl);
		}
	}
</style>
