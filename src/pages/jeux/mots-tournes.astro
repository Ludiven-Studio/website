---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import MotsTournesGame from '../../games/mots-tournes/MotsTournesGame.tsx';
import GameTutorial from '../../components/GameTutorial.astro';
---

<BaseLayout
	title="Mots Tournés | Jeux Ludiven Studio"
	description="Mots Tournés : un puzzle de mots français façon Wend. Trace chaque mot d'un thème en serpentant entre les lettres voisines — les chemins pavent toute la grille. Seules les longueurs sont données. Défi du jour à graine partagée, signé Ludiven Studio."
>
	<div class="wrapper game-page stack gap-8">
		<header class="game-head stack gap-2">
			<a class="back" href="/jeux/">
				<Icon icon="arrow-left" size="1em" /> Tous les jeux
			</a>
			<h1>Mots Tournés</h1>
			<p>Trace les mots en serpentant — les chemins pavent la grille</p>
			<GameTutorial gameId="mots-tournes" />
		</header>

		<MotsTournesGame client:only="react" gameId="mots-tournes" />
	</div>
</BaseLayout>

<style>
	.game-page {
		align-items: center;
	}
	.game-head {
		text-align: center;
		align-items: center;
	}
	.back {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		color: var(--gray-300);
		text-decoration: none;
		font-family: var(--font-brand);
		font-weight: 500;
		font-size: var(--text-sm);
	}
	.back:hover,
	.back:focus-visible {
		color: var(--accent-regular);
	}
	.game-head h1 {
		font-size: var(--text-3xl);
		margin-top: 0.5rem;
	}
	.game-head p {
		color: var(--gray-300);
	}
	@media (min-width: 50em) {
		.game-head h1 {
			font-size: var(--text-4xl);
		}
	}
</style>
