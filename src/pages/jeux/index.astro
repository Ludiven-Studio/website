---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GameCard from '../../components/GameCard.astro';
import { games } from '../../data/games';
---

<BaseLayout
	title="Jeux de logique | Ludiven Studio"
	description="Une collection de mini-jeux de logique à entraîner chaque jour, signés Ludiven Studio."
>
	<div class="wrapper stack gap-8 lg:gap-20">
		<header class="games-hero stack gap-2 lg:gap-4">
			<h1>Jeux de logique</h1>
			<p>
				Des mini-jeux de déduction pensés pour aiguiser ta logique en quelques minutes.
				Sept à découvrir — et d'autres arrivent.
			</p>
		</header>

		<ul class="games-grid">
			{
				games.map((game) => (
					<li>
						<GameCard
							id={game.id}
							title={game.title}
							pitch={game.pitch}
							icon={game.icon}
							href={game.href}
							status={game.status}
							favorite
						/>
					</li>
				))
			}
		</ul>

		<p class="games-note">
			Des mini-jeux de logique développés par Ludiven Studio, librement inspirés de grands
			classiques du genre. Sans affiliation avec leurs éditeurs respectifs.
		</p>
	</div>
</BaseLayout>

<style>
	.games-note {
		text-align: center;
		max-width: 60ch;
		margin-inline: auto;
		color: var(--gray-400);
		font-size: var(--text-sm);
	}

	.games-hero {
		text-align: center;
		max-width: 50ch;
		margin-inline: auto;
		color: var(--gray-300);
		font-size: var(--text-md);
	}

	.games-hero h1 {
		font-size: var(--text-3xl);
	}

	.games-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
		list-style: none;
		padding: 0;
		margin: 0;
	}

	@media (min-width: 50em) {
		.games-hero {
			font-size: var(--text-lg);
		}

		.games-hero h1 {
			font-size: var(--text-4xl);
		}

		.games-grid {
			grid-template-columns: repeat(3, 1fr);
			gap: 2rem;
		}
	}
</style>
