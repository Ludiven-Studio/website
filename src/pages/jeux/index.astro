---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GameCard from '../../components/GameCard.astro';
import GameFold from '../../components/GameFold.astro';
import SuggestionForm from '../../components/SuggestionForm.astro';
import CocottesPanel from '../../components/CocottesPanel';
import { games } from '../../data/games';

const NUM_FR = ['zéro', 'un', 'deux', 'trois', 'quatre', 'cinq', 'six', 'sept', 'huit', 'neuf', 'dix', 'onze', 'douze', 'treize', 'quatorze', 'quinze', 'seize'];
const playable = games.filter((g) => g.status === 'play').length;
const playableLabel = NUM_FR[playable]
	? NUM_FR[playable].charAt(0).toUpperCase() + NUM_FR[playable].slice(1)
	: String(playable);

// Collapsible category sections — fold ids/state shared with /jeux/defi.
const CATEGORIES = [
	{ id: 'logique', title: '🧩 Jeux de logique' },
	{ id: 'mots', title: '🔤 Jeux de mots' },
	{ id: 'adresse', title: "🎯 Jeux d'adresse" },
	{ id: 'multi', title: '⚽ Jeux multis' },
] as const;
const byCategory = CATEGORIES.map((c) => ({
	...c,
	games: games.filter((g) => (g.category ?? 'logique') === c.id),
})).filter((c) => c.games.length > 0);
---

<BaseLayout
	title="Mini-jeux | Ludiven Studio"
	description="Une collection de mini-jeux de logique et d'adresse à entraîner chaque jour, signés Ludiven Studio."
>
	<div class="wrapper stack gap-8 lg:gap-20">
		<header class="games-hero stack gap-2 lg:gap-4">
			<h1>Mini-jeux</h1>
			<p>
				Des mini-jeux pensés pour aiguiser ta logique ou tes réflexes en quelques minutes.
				{playableLabel} à découvrir — et d'autres arrivent.
			</p>
			<ul class="games-promise" aria-label="Nos engagements">
				<li>🆓 Gratuit</li>
				<li>🚫 Sans publicité</li>
				<li>🔓 Sans inscription</li>
			</ul>
			<a class="games-defi-cta" href="/jeux/defi">🏆 Le défi du jour</a>
				<p class="games-streak" id="games-streak" hidden></p>
		</header>

			<CocottesPanel client:load />

		<div class="games-sections stack gap-4">
			{
				byCategory.map((c) => (
					<GameFold id={c.id} title={c.title} count={c.games.length}>
						<ul class="games-grid">
							{c.games.map((game) => (
								<li>
									<GameCard
										id={game.id}
										title={game.title}
										pitch={game.pitch}
										icon={game.icon}
										href={game.href}
										status={game.status}
										image={game.image}
										daily={c.id !== 'multi'}
										favorite
									/>
								</li>
							))}
						</ul>
					</GameFold>
				))
			}
		</div>

		<SuggestionForm />

		<p class="games-note">
			Des mini-jeux de logique développés par Ludiven Studio, librement inspirés de grands
			classiques du genre. Sans affiliation avec leurs éditeurs respectifs.
		</p>
	</div>
</BaseLayout>

<style>
	.games-note {
		text-align: center;
		max-width: 60ch;
		margin-inline: auto;
		color: var(--gray-400);
		font-size: var(--text-sm);
	}

	.games-hero {
		text-align: center;
		max-width: 50ch;
		margin-inline: auto;
		color: var(--gray-300);
		font-size: var(--text-md);
	}

	.games-hero h1 {
		font-size: var(--text-3xl);
	}

	.games-promise {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		justify-content: center;
		padding: 0;
		margin: 0.25rem 0 0;
	}
	.games-promise li {
		background: var(--gray-999);
		border: 1px solid var(--gray-800);
		border-radius: 999px;
		padding: 5px 13px;
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--gray-100);
	}
	.games-defi-cta {
		align-self: center;
		margin-top: 0.5rem;
		background: var(--accent-regular);
		color: var(--accent-text-over);
		font-family: var(--font-brand);
		font-weight: 700;
		font-size: var(--text-md);
		text-decoration: none;
		border-radius: 999px;
		padding: 10px 22px;
		box-shadow: var(--shadow-md);
		transition: filter var(--theme-transition);
	}
	.games-defi-cta:hover,
	.games-defi-cta:focus-visible {
		filter: brightness(1.06);
	}

	.games-streak {
		align-self: center;
		margin-top: 0.6rem;
		font-weight: 800;
		font-size: var(--text-md);
		color: var(--gray-0);
		background: rgba(245, 166, 35, 0.14);
		border: 1px solid rgba(245, 166, 35, 0.5);
		border-radius: 999px;
		padding: 7px 18px;
	}
	.games-streak .games-streak-note {
		font-weight: 600;
		color: var(--gray-200);
	}

	.games-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
		list-style: none;
		padding: 0;
		margin: 0;
	}

	@media (min-width: 50em) {
		.games-hero {
			font-size: var(--text-lg);
		}

		.games-hero h1 {
			font-size: var(--text-4xl);
		}

		.games-grid {
			grid-template-columns: repeat(3, 1fr);
			gap: 2rem;
		}
	}
</style>

<script>
	import { activityStreak } from '../../lib/streak';

	const el = document.getElementById('games-streak');
	const refresh = () => {
		if (!el) return;
		el.hidden = false;
		const s = activityStreak();
		if (s.count > 0) {
			const note = s.atRisk ? ' <span class="games-streak-note">· joue aujourd\'hui pour la garder</span>' : '';
			el.innerHTML = `🔥 ${s.count} jour${s.count > 1 ? 's' : ''} d'affilée${note}`;
		} else {
			el.innerHTML = `🔥 <span class="games-streak-note">Joue un jeu aujourd'hui pour lancer ta série</span>`;
		}
	};
	refresh();
	document.addEventListener('visibilitychange', () => { if (!document.hidden) refresh(); });
	window.addEventListener('pageshow', refresh);
</script>
