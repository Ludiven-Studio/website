---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GameCard from '../../components/GameCard.astro';
import SuggestionForm from '../../components/SuggestionForm.astro';
import { games } from '../../data/games';

const NUM_FR = ['zéro', 'un', 'deux', 'trois', 'quatre', 'cinq', 'six', 'sept', 'huit', 'neuf', 'dix', 'onze', 'douze', 'treize', 'quatorze', 'quinze', 'seize'];
const playable = games.filter((g) => g.status === 'play').length;
const playableLabel = NUM_FR[playable]
	? NUM_FR[playable].charAt(0).toUpperCase() + NUM_FR[playable].slice(1)
	: String(playable);

const logique = games.filter((g) => (g.category ?? 'logique') === 'logique');
const adresse = games.filter((g) => g.category === 'adresse');
const multi = games.filter((g) => g.category === 'multi');
---

<BaseLayout
	title="Jeux | Ludiven Studio"
	description="Une collection de mini-jeux de logique et d'adresse à entraîner chaque jour, signés Ludiven Studio."
>
	<div class="wrapper stack gap-8 lg:gap-20">
		<header class="games-hero stack gap-2 lg:gap-4">
			<h1>Jeux</h1>
			<p>
				Des mini-jeux pensés pour aiguiser ta logique ou tes réflexes en quelques minutes.
				{playableLabel} à découvrir — et d'autres arrivent.
			</p>
		</header>

		<section class="games-section stack gap-6">
			<h2 class="games-section-title">Jeux de logique</h2>
			<ul class="games-grid">
				{
					logique.map((game) => (
						<li>
							<GameCard
								id={game.id}
								title={game.title}
								pitch={game.pitch}
								icon={game.icon}
								href={game.href}
								status={game.status}
								favorite
							/>
						</li>
					))
				}
			</ul>
		</section>

		{
			adresse.length > 0 && (
				<section class="games-section stack gap-6">
					<h2 class="games-section-title">Jeux d'adresse</h2>
					<ul class="games-grid">
						{adresse.map((game) => (
							<li>
								<GameCard
									id={game.id}
									title={game.title}
									pitch={game.pitch}
									icon={game.icon}
									href={game.href}
									status={game.status}
									favorite
								/>
							</li>
						))}
					</ul>
				</section>
			)
		}

		{
			multi.length > 0 && (
				<section class="games-section stack gap-6">
					<h2 class="games-section-title">Jeux multis</h2>
					<ul class="games-grid">
						{multi.map((game) => (
							<li>
								<GameCard
									id={game.id}
									title={game.title}
									pitch={game.pitch}
									icon={game.icon}
									href={game.href}
									status={game.status}
									favorite
								/>
							</li>
						))}
					</ul>
				</section>
			)
		}

		<SuggestionForm />

		<p class="games-note">
			Des mini-jeux de logique développés par Ludiven Studio, librement inspirés de grands
			classiques du genre. Sans affiliation avec leurs éditeurs respectifs.
		</p>
	</div>
</BaseLayout>

<style>
	.games-note {
		text-align: center;
		max-width: 60ch;
		margin-inline: auto;
		color: var(--gray-400);
		font-size: var(--text-sm);
	}

	.games-hero {
		text-align: center;
		max-width: 50ch;
		margin-inline: auto;
		color: var(--gray-300);
		font-size: var(--text-md);
	}

	.games-hero h1 {
		font-size: var(--text-3xl);
	}

	.games-section-title {
		font-size: var(--text-xl);
		text-align: center;
		margin: 0;
		color: var(--gray-0);
	}

	.games-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
		list-style: none;
		padding: 0;
		margin: 0;
	}

	@media (min-width: 50em) {
		.games-hero {
			font-size: var(--text-lg);
		}

		.games-hero h1 {
			font-size: var(--text-4xl);
		}

		.games-grid {
			grid-template-columns: repeat(3, 1fr);
			gap: 2rem;
		}
	}
</style>
