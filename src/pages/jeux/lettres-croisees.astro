---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import LettresCroiseesGame from '../../games/lettres-croisees/LettresCroiseesGame.tsx';
import GameTutorial from '../../components/GameTutorial.astro';
---

<BaseLayout
	title="Lettres Croisées | Jeux Ludiven Studio"
	description="Lettres Croisées : compose des mots français avec les lettres de la roue et remplis la grille croisée. Les mots valides hors grille comptent en bonus. Défi du jour à graine partagée, signé Ludiven Studio."
>
	<div class="wrapper game-page stack gap-8">
		<header class="game-head stack gap-2">
			<a class="back" href="/jeux/">
				<Icon icon="arrow-left" size="1em" /> Tous les jeux
			</a>
			<h1>Lettres Croisées</h1>
			<p>Compose des mots avec la roue — remplis la grille croisée</p>
			<GameTutorial gameId="lettres-croisees" />
		</header>

		<LettresCroiseesGame client:only="react" gameId="lettres-croisees" />
	</div>
</BaseLayout>

<style>
	.game-page {
		align-items: center;
	}
	.game-head {
		text-align: center;
		align-items: center;
	}
	.back {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		color: var(--gray-300);
		text-decoration: none;
		font-family: var(--font-brand);
		font-weight: 500;
		font-size: var(--text-sm);
	}
	.back:hover,
	.back:focus-visible {
		color: var(--accent-regular);
	}
	.game-head h1 {
		font-size: var(--text-3xl);
		margin-top: 0.5rem;
	}
	.game-head p {
		color: var(--gray-300);
	}
	@media (min-width: 50em) {
		.game-head h1 {
			font-size: var(--text-4xl);
		}
	}
</style>
