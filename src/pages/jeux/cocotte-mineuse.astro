---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import CocotteMineuseGame from '../../games/cocotte-mineuse/CocotteMineuseGame.tsx';
import GameTutorial from '../../components/GameTutorial.astro';
---

<BaseLayout
	title="Cocotte Mineuse | Jeux Ludiven Studio"
	description="Cocotte Mineuse : creuse dans le sable, esquive les pierres qui tombent, collecte les minerais et crafte torches et bijoux avant que la lampe ne s'éteigne. Défi du jour et classement. Un jeu Ludiven Studio."
>
	<div class="wrapper game-page stack gap-8">
		<header class="game-head stack gap-2">
			<a class="back" href="/jeux/">
				<Icon icon="arrow-left" size="1em" /> Tous les jeux
			</a>
			<h1>Cocotte Mineuse</h1>
			<p>Creuse, esquive les pierres, crafte avant la nuit</p>
			<GameTutorial gameId="cocotte-mineuse" />
		</header>

		<CocotteMineuseGame client:only="react" gameId="cocotte-mineuse" />
	</div>
</BaseLayout>

<style>
	.game-page {
		align-items: center;
	}
	.game-head {
		text-align: center;
		align-items: center;
	}
	.back {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		color: var(--gray-300);
		text-decoration: none;
		font-family: var(--font-brand);
		font-weight: 500;
		font-size: var(--text-sm);
	}
	.back:hover,
	.back:focus-visible {
		color: var(--accent-regular);
	}
	.game-head h1 {
		font-size: var(--text-3xl);
		margin-top: 0.5rem;
	}
	.game-head p {
		color: var(--gray-300);
	}
	@media (min-width: 50em) {
		.game-head h1 {
			font-size: var(--text-4xl);
		}
	}
</style>
