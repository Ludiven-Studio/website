---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import AlchimieGame from '../../games/alchimie/AlchimieGame.tsx';
import GameTutorial from '../../components/GameTutorial.astro';
---

<BaseLayout
	title="Alchimie | Jeux Ludiven Studio"
	description="Alchimie : pars de 5 éléments de base (feu, eau, terre, air, bois) et combine-les deux par deux sur l'établi pour découvrir près de 150 éléments — pierre, vie, dragon, robot, licorne… Chaque trouvaille se révèle avec panache. Un jeu Ludiven Studio."
>
	<div class="wrapper game-page stack gap-8">
		<header class="game-head stack gap-2">
			<a class="back" href="/jeux/">
				<Icon icon="arrow-left" size="1em" /> Tous les jeux
			</a>
			<h1>Alchimie</h1>
			<p>Combine les éléments et découvre-les tous</p>
			<GameTutorial gameId="alchimie" />
		</header>

		<AlchimieGame client:only="react" gameId="alchimie" />
	</div>
</BaseLayout>

<style>
	.game-page {
		align-items: center;
	}
	.game-head {
		text-align: center;
		align-items: center;
	}
	.back {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		color: var(--gray-300);
		text-decoration: none;
		font-family: var(--font-brand);
		font-weight: 500;
		font-size: var(--text-sm);
	}
	.back:hover,
	.back:focus-visible {
		color: var(--accent-regular);
	}
	.game-head h1 {
		font-size: var(--text-3xl);
		margin-top: 0.5rem;
	}
	.game-head p {
		color: var(--gray-300);
	}
	@media (min-width: 50em) {
		.game-head h1 {
			font-size: var(--text-4xl);
		}
	}
</style>
