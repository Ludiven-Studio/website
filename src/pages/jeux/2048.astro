---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import Game2048 from '../../games/2048/Game2048.tsx';
import GameTutorial from '../../components/GameTutorial.astro';
---

<BaseLayout
	title="2048 | Jeux Ludiven Studio"
	description="2048 : fais glisser et fusionne les tuiles pour atteindre 2048 et battre ton meilleur score. Défi du jour à graine partagée et classement. Un jeu de logique signé Ludiven Studio."
>
	<div class="wrapper game-page stack gap-8">
		<header class="game-head stack gap-2">
			<a class="back" href="/jeux/">
				<Icon icon="arrow-left" size="1em" /> Tous les jeux
			</a>
			<h1>2048</h1>
			<p>Glisse, fusionne, atteins 2048</p>
			<GameTutorial gameId="2048" />
		</header>

		<Game2048 client:only="react" gameId="2048" />
	</div>
</BaseLayout>

<style>
	.game-page {
		align-items: center;
	}
	.game-head {
		text-align: center;
		align-items: center;
	}
	.back {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		color: var(--gray-300);
		text-decoration: none;
		font-family: var(--font-brand);
		font-weight: 500;
		font-size: var(--text-sm);
	}
	.back:hover,
	.back:focus-visible {
		color: var(--accent-regular);
	}
	.game-head h1 {
		font-size: var(--text-3xl);
		margin-top: 0.5rem;
	}
	.game-head p {
		color: var(--gray-300);
	}
	@media (min-width: 50em) {
		.game-head h1 {
			font-size: var(--text-4xl);
		}
	}
</style>
