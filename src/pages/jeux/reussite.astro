---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import ReussiteGame from '../../games/reussite/ReussiteGame.tsx';
import GameTutorial from '../../components/GameTutorial.astro';
---

<BaseLayout
	title="Réussite (solitaire aux cartes) | Jeux Ludiven Studio"
	description="La Réussite (Klondike) : le solitaire aux cartes. Monte les quatre familles de l'As au Roi, en pioche 1 ou 3 cartes. Tape pour l'envoi automatique ou glisse les cartes. Défi du jour à graine partagée, signé Ludiven Studio."
>
	<div class="wrapper game-page stack gap-8">
		<header class="game-head stack gap-2">
			<a class="back" href="/jeux/">
				<Icon icon="arrow-left" size="1em" /> Tous les jeux
			</a>
			<h1>Réussite</h1>
			<p>Le solitaire aux cartes — monte les familles de l'As au Roi</p>
			<GameTutorial gameId="reussite" />
		</header>

		<ReussiteGame client:only="react" gameId="reussite" />
	</div>
</BaseLayout>

<style>
	.game-page {
		align-items: center;
	}
	.game-head {
		text-align: center;
		align-items: center;
	}
	.back {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		color: var(--gray-300);
		text-decoration: none;
		font-family: var(--font-brand);
		font-weight: 500;
		font-size: var(--text-sm);
	}
	.back:hover,
	.back:focus-visible {
		color: var(--accent-regular);
	}
	.game-head h1 {
		font-size: var(--text-3xl);
		margin-top: 0.5rem;
	}
	.game-head p {
		color: var(--gray-300);
	}
	@media (min-width: 50em) {
		.game-head h1 {
			font-size: var(--text-4xl);
		}
	}
</style>
