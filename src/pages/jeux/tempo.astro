---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import TempoGame from '../../games/tempo/TempoGame.tsx';
import GameTutorial from '../../components/GameTutorial.astro';
---

<BaseLayout
	title="Tempo (proto) | Jeux Ludiven Studio"
	description="Prototype : un piano tiles sur des airs connus. Tape les tuiles pile sur la ligne pour jouer la mélodie. Combos, rangs et défi du jour."
>
	<div class="wrapper game-page stack gap-8">
		<header class="game-head stack gap-2">
			<a class="back" href="/jeux/">
				<Icon icon="arrow-left" size="1em" /> Tous les jeux
			</a>
			<h1>Tempo</h1>
			<p>Prototype — tape les tuiles en rythme pour jouer l'air</p>
			<GameTutorial gameId="tempo" />
		</header>

		<TempoGame client:only="react" gameId="tempo" />
	</div>
</BaseLayout>

<style>
	.game-page {
		align-items: center;
	}
	.game-head {
		text-align: center;
		align-items: center;
	}
	.back {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		color: var(--gray-300);
		text-decoration: none;
		font-family: var(--font-brand);
		font-weight: 500;
		font-size: var(--text-sm);
	}
	.back:hover,
	.back:focus-visible {
		color: var(--accent-regular);
	}
	.game-head h1 {
		font-size: var(--text-3xl);
		margin-top: 0.5rem;
	}
	.game-head p {
		color: var(--gray-300);
	}
	@media (min-width: 50em) {
		.game-head h1 {
			font-size: var(--text-4xl);
		}
	}
</style>
