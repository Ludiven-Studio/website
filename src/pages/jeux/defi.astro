---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GameCard from '../../components/GameCard.astro';
import GameFold from '../../components/GameFold.astro';
import Icon from '../../components/Icon.astro';
import { games } from '../../data/games';

// Every playable game now has a daily challenge (Pong & Foot race the AI to 3), so the
// hub lists them all — same count as the /jeux catalogue.
const dailyGames = games.filter((g) => g.status === 'play');

// Collapsible category sections (42 games is too long for one flat grid).
const CATEGORIES = [
	{ id: 'logique', title: '🧩 Logique' },
	{ id: 'mots', title: '🔤 Mots' },
	{ id: 'adresse', title: '🎯 Adresse' },
	{ id: 'multi', title: '⚽ Duels' },
] as const;
const byCategory = CATEGORIES.map((c) => ({
	...c,
	games: dailyGames.filter((g) => (g.category ?? 'logique') === c.id),
})).filter((c) => c.games.length > 0);
---

<BaseLayout
	title="Défi du jour | Jeux Ludiven Studio"
	description="Le défi du jour : chaque jour, le même niveau pour tout le monde. Fais ton meilleur score, compare-toi au classement et partage. Gratuit, sans pub, sans inscription."
>
	<div class="wrapper stack gap-8">
		<header class="defi-hero stack gap-3">
			<a class="back" href="/jeux/">
				<Icon icon="arrow-left" size="1em" /> Tous les jeux
			</a>
			<h1>🏆 Le défi du jour</h1>
			<p>
				Chaque jour, le <strong>même niveau pour tout le monde</strong>. Fais ton meilleur score,
				compare-toi au classement et <strong>partage-le</strong> — le lien ouvre directement le défi.
				Ton <strong>record du jour</strong> s'affiche sur chaque jeu.
			</p>
			<ul class="games-promise" aria-label="Nos engagements">
				<li>🆓 Gratuit</li>
				<li>🚫 Sans publicité</li>
				<li>🔓 Sans inscription</li>
			</ul>
			<p class="defi-streak" id="defi-streak" hidden></p>
			<p class="defi-count" id="defi-count" aria-live="polite"></p>
		</header>

		<div class="defi-sections stack gap-4">
			{
				byCategory.map((c) => (
					<GameFold id={c.id} title={c.title} count={c.games.length}>
						<ul class="defi-grid">
							{c.games.map((g) => (
								<li>
									<GameCard id={g.id} title={g.title} pitch={g.pitch} icon={g.icon} href={`${g.href}?defi`} status={g.status} compact />
								</li>
							))}
						</ul>
					</GameFold>
				))
			}
		</div>
	</div>
</BaseLayout>

<style>
	.defi-hero {
		text-align: center;
		max-width: 54ch;
		margin-inline: auto;
		align-items: center;
		color: var(--gray-300);
		font-size: var(--text-md);
	}
	.defi-hero h1 {
		font-size: var(--text-3xl);
	}
	.defi-hero strong {
		color: var(--gray-0);
	}
	.back {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		color: var(--gray-300);
		text-decoration: none;
		font-family: var(--font-brand);
		font-weight: 500;
		font-size: var(--text-sm);
	}
	.back:hover,
	.back:focus-visible {
		color: var(--accent-regular);
	}
	.games-promise {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		justify-content: center;
		padding: 0;
		margin: 0.25rem 0 0;
	}
	.games-promise li {
		background: var(--gray-999);
		border: 1px solid var(--gray-800);
		border-radius: 999px;
		padding: 5px 13px;
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--gray-100);
	}
	.defi-count {
		font-weight: 700;
		color: var(--accent-regular);
		font-size: var(--text-md);
		margin-top: 0.35rem;
	}
	.defi-grid {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(158px, 1fr));
		gap: 0.85rem;
	}
	/* compact tiles: tighter than the full cards on /jeux */
	.defi-grid :global(.game-card) {
		padding: 1rem 1.1rem;
		gap: 0.55rem;
		border-radius: 1.1rem;
	}
	.defi-grid :global(.game-card h3) {
		font-size: var(--text-base);
	}
	/* done challenges fade back so the ones left to do stand out */
	.defi-grid li.is-done { opacity: 0.5; transition: opacity var(--theme-transition); }
	.defi-grid li.is-done:hover { opacity: 0.85; }

	.defi-streak {
		align-self: center;
		font-weight: 800;
		font-size: var(--text-md);
		color: var(--gray-0);
		background: var(--accent-overlay);
		border: 1px solid var(--accent-regular);
		border-radius: 999px;
		padding: 6px 16px;
		margin-top: 0.35rem;
	}
	.defi-streak .defi-streak-note {
		font-weight: 600;
		color: var(--gray-200);
	}
</style>

<script>
	import { globalStreak } from '../../lib/streak';

	const todayKey = () => {
		const d = new Date();
		return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
	};
	const grids = Array.from(document.querySelectorAll<HTMLUListElement>('.defi-grid'));
	const counter = document.getElementById('defi-count');
	const streakEl = document.getElementById('defi-streak');

	const refreshStreak = () => {
		if (!streakEl) return;
		const s = globalStreak();
		if (s.count > 0) {
			streakEl.hidden = false;
			const note = s.atRisk ? ' <span class="defi-streak-note">· joue aujourd\'hui pour la garder</span>' : '';
			streakEl.innerHTML = `🔥 ${s.count} jour${s.count > 1 ? 's' : ''} d'affilée${note}`;
		} else {
			streakEl.hidden = true;
		}
	};

	const refresh = () => {
		refreshStreak();
		const day = todayKey();
		let done = 0, total = 0;
		for (const grid of grids) {
			const lis = Array.from(grid.children) as HTMLElement[];
			let sectionDone = 0;
			const ranked = lis.map((li, i) => {
				const id = li.querySelector('[data-game-id]')?.getAttribute('data-game-id');
				let s = 0; // 0 = à faire, 1 = en cours, 2 = fait
				try {
					const raw = id ? localStorage.getItem(`ludiven-dailyrun-${id}-${day}`) : null;
					if (raw) s = JSON.parse(raw)?.done === true ? 2 : 1;
				} catch { /* ignore */ }
				li.classList.toggle('is-done', s === 2);
				li.classList.toggle('is-progress', s === 1);
				if (s === 2) sectionDone++;
				return { li, s, i };
			});
			// à faire → en cours → fait (stable within a group)
			ranked.sort((a, b) => a.s - b.s || a.i - b.i);
			for (const { li } of ranked) grid.appendChild(li);
			done += sectionDone;
			total += lis.length;
			// Per-section progress in the fold header ("3/12 faits").
			const meta = grid.closest('.game-fold')?.querySelector('[data-fold-meta]');
			if (meta) meta.textContent = sectionDone === lis.length
				? '✓ tout fait'
				: `${sectionDone}/${lis.length} fait${sectionDone > 1 ? 's' : ''}`;
		}
		const todo = total - done;
		if (counter) counter.textContent = todo === 0
			? '🎉 Tous les défis du jour sont faits !'
			: `${todo} défi${todo > 1 ? 's' : ''} à faire aujourd'hui · ${done}/${total} fait${done > 1 ? 's' : ''}`;
	};

	refresh();
	document.addEventListener('visibilitychange', () => { if (!document.hidden) refresh(); });
	window.addEventListener('pageshow', refresh);
</script>
