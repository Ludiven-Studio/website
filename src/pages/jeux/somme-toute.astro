---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import SommeTouteGame from '../../games/somme-toute/SommeToute.tsx';
import GameTutorial from '../../components/GameTutorial.astro';
---

<BaseLayout
	title="Somme Toute | Jeux Ludiven Studio"
	description="Remplis la grille pour que chaque ligne et chaque colonne atteigne sa somme cible. Un mini-jeu de logique signé Ludiven Studio."
>
	<div class="wrapper game-page stack gap-8">
		<header class="game-head stack gap-2">
			<a class="back" href="/jeux/">
				<Icon icon="arrow-left" size="1em" /> Tous les jeux
			</a>
			<h1>Somme Toute</h1>
			<p>Équilibre chaque ligne et chaque colonne</p>
			<GameTutorial gameId="somme-toute" />
		</header>

		<SommeTouteGame client:only="react" gameId="somme-toute" />
	</div>
</BaseLayout>

<style>
	.game-page {
		align-items: center;
	}

	.game-head {
		text-align: center;
		align-items: center;
	}

	.back {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		color: var(--gray-300);
		text-decoration: none;
		font-family: var(--font-brand);
		font-weight: 500;
		font-size: var(--text-sm);
	}

	.back:hover,
	.back:focus-visible {
		color: var(--accent-regular);
	}

	.game-head h1 {
		font-size: var(--text-3xl);
		margin-top: 0.5rem;
	}

	.game-head p {
		color: var(--gray-300);
	}

	@media (min-width: 50em) {
		.game-head h1 {
			font-size: var(--text-4xl);
		}
	}
</style>
