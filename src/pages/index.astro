---
import { getCollection } from 'astro:content';

// Layout import — provides basic page elements: <head>, <nav>, <footer> etc.
import BaseLayout from '../layouts/BaseLayout.astro';

// Component Imports
import CallToAction from '../components/CallToAction.astro';
import GameCard from '../components/GameCard.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Pill from '../components/Pill.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import { games } from '../data/games';

// Page section components
import ContactCTA from '../components/ContactCTA.astro';
import Skills from '../components/Skills.astro';

// Content Fetching: List four most recent work projects
const projects = (await getCollection('work'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 4);

// Full Astro Component Syntax:
// https://docs.astro.build/basics/astro-components/
---

<BaseLayout>
	<div class="stack gap-20 lg:gap-48">
		<div class="wrapper stack gap-8 lg:gap-20">
			<header class="hero">
				<Hero
					title="Bienvenue chez Ludiven Studio"
					tagline="Le studio qui vous accompagne dans vos projets numériques, jeux et applications"
					align="start"
				>
					<div class="roles">
						<Pill><Icon icon="games" size="1.33em" /> Jeux-Vidéos</Pill>
						<Pill><Icon icon="mobile" size="1.33em" /> Applications mobiles</Pill>
						<Pill><Icon icon="virtual-reality" size="1.33em" /> Réalité Virtuelle</Pill>
					</div>
				</Hero>

				<img
					alt="Ludiven Studio"
					width="520"
					height="390"
					src="/assets/LudivenStudioLogo.png"
				/>
			</header>

			<Skills />
		</div>

		<main class="wrapper stack gap-20 lg:gap-48">
			<section class="section with-background with-cta" id="games-section">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3 data-games-title data-default-title="Jeux de logique" data-fav-title="Mes favoris">Jeux de logique</h3>
					<p>Entraîne ta logique avec des mini-jeux de déduction. Quelques minutes par jour, sans prise de tête.</p>
				</header>

				<div class="gallery">
					<ul class="games-teaser" data-teaser-default>
						<li>
							<GameCard
								title="Somme Toute"
								pitch="Équilibre chaque ligne et chaque colonne pour atteindre la somme cible."
								icon="strategy"
								href="/jeux/somme-toute"
								status="play"
							/>
						</li>
						<li>
							<GameCard
								title="Sudoku"
								pitch="Le grand classique, en 4×4, 6×6 ou 9×9, à plusieurs niveaux."
								icon="games"
								href="/jeux/sudoku"
								status="play"
							/>
						</li>
						<li class="teaser-extra">
							<GameCard
								title="Reines"
								pitch="Une reine par ligne, colonne et couleur, façon LinkedIn Queens."
								icon="trophy"
								href="/jeux/reines"
								status="play"
							/>
						</li>
					</ul>

					<ul class="games-teaser" data-teaser-favorites hidden>
						{
							games
								.filter((game) => game.status === 'play')
								.map((game) => (
									<li data-game-id={game.id} hidden>
										<GameCard
											title={game.title}
											pitch={game.pitch}
											icon={game.icon}
											href={game.href}
											status={game.status}
										/>
									</li>
								))
						}
					</ul>
				</div>

				<div class="cta">
					<CallToAction href="/jeux/">
						Tous les jeux
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>

			<section class="section with-background with-cta">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Projets & réalisations</h3>
					<p>Un aperçu de mon savoir-faire : projets récents et collaborations menées au fil des années</p>
				</header>

				<div class="gallery">
					<Grid variant="offset">
						{
							projects.map((project) => (
								<li>
									<PortfolioPreview project={project} />
								</li>
							))
						}
					</Grid>
				</div>

				<div class="cta">
					<CallToAction href="/work/">
						Tous les projets
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>
<!-- 
			<section class="section with-background bg-variant">
				
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Mentions</h3>
					<p>
						I have been fortunate enough to receive praise for my work in several publications. Take
						a look below to learn more.
					</p>
				</header>				
				<div class="gallery">
					<Grid variant="small">
						{
							['Medium', 'BuzzFeed', 'The Next Web', 'awwwards.', 'TechCrunch'].map((brand) => (
								<li class="mention-card">
									<p>{brand}</p>
								</li>
							))
						}
					</Grid>
				</div>
			</section>
-->
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<script>
	// Lead the home teaser with the visitor's favorites. Fewer than 3 favorites →
	// favorites first, then fill up to 3 with other games. 3+ favorites → favorites only.
	const MIN = 3;

	let favs: string[] = [];
	try {
		favs = JSON.parse(localStorage.getItem('ludiven-favorites') || '[]');
	} catch {
		favs = [];
	}

	const favList = document.querySelector('[data-teaser-favorites]');
	if (Array.isArray(favs) && favs.length && favList) {
		const items = Array.from(favList.querySelectorAll<HTMLElement>('[data-game-id]'));
		const byId = new Map(items.map((li) => [li.dataset.gameId || '', li]));
		const allIds = items.map((li) => li.dataset.gameId || ''); // registry order
		const favIds = favs.filter((id) => byId.has(id)); // visitor order, existing games

		const showIds =
			favIds.length >= MIN
				? favIds
				: [...favIds, ...allIds.filter((id) => !favIds.includes(id))].slice(0, MIN);

		if (showIds.length) {
			items.forEach((li) => (li.hidden = true));
			showIds.forEach((id) => {
				const li = byId.get(id);
				if (li) {
					li.hidden = false;
					favList.appendChild(li); // reorder: favorites first
				}
			});

			document.querySelector('[data-teaser-default]')?.setAttribute('hidden', '');
			favList.removeAttribute('hidden');

			const title = document.querySelector<HTMLElement>('[data-games-title]');
			if (favIds.length >= MIN && title) title.textContent = title.dataset.favTitle || title.textContent;
		}
	}
</script>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
	}

	.roles {
		display: none;
	}

	.hero img {
		width: 100%;
		max-width: 28rem;
		height: auto;
		object-fit: contain;
	}

	@media (min-width: 50em) {
		.hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			padding-inline: 2.5rem;
			gap: 3.75rem;
			align-items: center;
		}

		.roles {
			margin-top: 0.5rem;
			display: flex;
			gap: 0.5rem;
		}

		.hero img {
			max-width: 100%;
		}
	}

	/* ====================================================== */

	.section {
		display: grid;
		gap: 2rem;
	}

	.with-background {
		position: relative;
	}

	.with-background::before {
		--hero-bg: var(--bg-image-subtle-2);

		content: '';
		position: absolute;
		pointer-events: none;
		left: 50%;
		width: 100vw;
		aspect-ratio: calc(2.25 / var(--bg-scale));
		top: 0;
		transform: translateY(-75%) translateX(-50%);
		background:
			url('/assets/backgrounds/noise.png') top center/220px repeat,
			var(--hero-bg) center center / var(--bg-gradient-size) no-repeat,
			var(--gray-999);
		background-blend-mode: overlay, normal, normal, normal;
		mix-blend-mode: var(--bg-blend-mode);
		z-index: -1;
	}

	.with-background.bg-variant::before {
		--hero-bg: var(--bg-image-subtle-1);
	}

	.section-header {
		justify-self: center;
		text-align: center;
		max-width: 50ch;
		font-size: var(--text-md);
		color: var(--gray-300);
	}

	.section-header h3 {
		font-size: var(--text-2xl);
	}

	@media (min-width: 50em) {
		.section {
			grid-template-columns: repeat(4, 1fr);
			grid-template-areas: 'header header header header' 'gallery gallery gallery gallery';
			gap: 5rem;
		}

		.section.with-cta {
			grid-template-areas: 'header header header cta' 'gallery gallery gallery gallery';
		}

		.section-header {
			grid-area: header;
			font-size: var(--text-lg);
		}

		.section-header h3 {
			font-size: var(--text-4xl);
		}

		.with-cta .section-header {
			justify-self: flex-start;
			text-align: left;
		}

		.gallery {
			grid-area: gallery;
		}

		.cta {
			grid-area: cta;
		}
	}

	/* ====================================================== */

	.games-teaser {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
		list-style: none;
		padding: 0;
		margin: 0;
	}

	/* Let the `hidden` attribute actually hide a teaser list (display:grid would win). */
	.games-teaser[hidden] {
		display: none;
	}

	@media (min-width: 50em) {
		.games-teaser {
			grid-template-columns: repeat(3, 1fr);
			gap: 2rem;
		}
	}

	/* ====================================================== */

	.mention-card {
		display: flex;
		height: 7rem;
		justify-content: center;
		align-items: center;
		text-align: center;
		border: 1px solid var(--gray-800);
		border-radius: 1.5rem;
		color: var(--gray-300);
		background: var(--gradient-subtle);
		box-shadow: var(--shadow-sm);
	}

	@media (min-width: 50em) {
		.mention-card {
			border-radius: 1.5rem;
			height: 9.5rem;
		}
	}
</style>
