---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import ContactCTA from '../components/ContactCTA.astro';
import type { iconPaths } from '../components/IconPaths';

// Une seule grille de cartouches : 5 prestations principales puis des interventions plus fines.
const services: { icon: keyof typeof iconPaths; title: string; body: string }[] = [
	{ icon: 'code', title: 'Développement Unity', body: 'De l\'idée au produit livré : applications et jeux sous Unity — mobile, desktop et WebGL — avec un code pensé pour durer.' },
	{ icon: 'mobile', title: 'Application mobile', body: 'Vos applications iOS et Android développées sous Unity, jusqu\'à la publication sur les stores, avec accès aux fonctions natives.' },
	{ icon: 'virtual-reality', title: 'Réalité virtuelle / XR', body: 'Des expériences immersives VR/XR pour la formation, la simulation ou le jeu, sur casque comme sur mobile.' },
	{ icon: 'strategy', title: 'Multijoueur Unity', body: 'Du temps réel qui tient la route : synchronisation, netcode, serveurs headless, du prototype à la production.' },
	{ icon: 'scales', title: 'Audit & reprise de projet Unity', body: 'Audit, correction de bugs, optimisation et montée de version pour sécuriser votre base de code et la remettre en mouvement.' },
	{ icon: 'pencil-line', title: 'Suivi d\'alternants & juniors', body: 'Encadrement technique, revues de code et montée en compétence des développeurs juniors.' },
	{ icon: 'terminal-window', title: 'Formation Unity & C#', body: 'Des sessions sur-mesure pour prendre en main Unity et le langage C#.' },
	{ icon: 'strategy', title: 'Structuration de projet', body: 'Architecture, organisation du code et bonnes pratiques pour un projet Unity qui reste sain.' },
	{ icon: 'flask', title: 'Problèmes techniques complexes', body: 'Un blocage tenace ? Je trouve et mets en place la solution technique adaptée.' },
	{ icon: 'scales', title: 'Optimisation (perfs, mémoire, build)', body: 'Plus de fluidité, moins de mémoire consommée et un build plus léger.' },
	{ icon: 'code', title: 'AssetBundles & Addressables', body: 'Chargement et gestion des ressources à la demande, proprement.' },
	{ icon: 'games', title: 'Gameplays sur-mesure', body: 'Des mécaniques de jeu originales, conçues et développées selon votre idée.' },
	{ icon: 'winding-path', title: 'Moteur physique', body: 'Collisions, simulations et interactions physiques réglées finement.' },
	{ icon: 'strategy', title: 'Multijoueur Photon / Netcode', body: 'Fonctionnalités temps réel avec Photon ou Netcode for GameObjects.' },
	{ icon: 'games', title: 'Interfaces & menus (UI)', body: 'Des interfaces et menus in-game clairs, réactifs et agréables à utiliser.' },
	{ icon: 'heart', title: 'Sons & musiques', body: 'Intégration audio (SFX, musiques) avec réglages de volume.' },
	{ icon: 'paper-plane-tilt', title: 'Localisation multilingue', body: 'Des textes prêts à être traduits et affichés en plusieurs langues.' },
	{ icon: 'terminal-window', title: 'Outils internes sur-mesure', body: 'Une boîte à outils maison, affinée au fil des projets pour gagner du temps.' },
	{ icon: 'flask', title: 'Cheat codes de debug', body: 'Des raccourcis de test pour accélérer le développement et la QA.' },
];

const title = 'Services — Développement Unity, mobile, VR & multijoueur | Ludiven Studio';
const description = 'Prestations de développement Unity : applications mobiles, jeux, expériences VR/XR et multijoueur temps réel, de la conception à la mise en production. Développeur Unity depuis 2010, en France et à distance.';

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'ProfessionalService',
	name: 'Ludiven Studio',
	url: 'https://www.ludiven-studio.fr/services/',
	description,
	areaServed: { '@type': 'Country', name: 'France' },
	provider: { '@type': 'Organization', name: 'Ludiven Studio', url: 'https://www.ludiven-studio.fr/' },
	serviceType: services.map((s) => s.title),
};
---

<BaseLayout title={title} description={description}>
	<div class="stack gap-20">
		<main class="wrapper stack gap-12">
			<Hero
				title="Services"
				tagline="Développeur Unity depuis 2010, je vous accompagne de la conception à la mise en production : applications, jeux et expériences immersives — en France comme à distance."
				align="start"
			/>

			<section class="box services">
				{services.map((s) => (
					<div class="stack gap-2 lg:gap-4">
						<Icon icon={s.icon} color="var(--accent-regular)" size="2.5rem" gradient />
						<h2>{s.title}</h2>
						<p>{s.body}</p>
					</div>
				))}
			</section>
		</main>

		<ContactCTA />
	</div>

	<script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
</BaseLayout>

<style>
	.box {
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		padding: 1.5rem;
		background-color: var(--gray-999_40);
		box-shadow: var(--shadow-sm);
	}

	.services {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2.5rem;
	}

	.services h2 {
		font-size: var(--text-lg);
	}

	.services p {
		color: var(--gray-400);
	}

	@media (min-width: 50em) {
		.box {
			border-radius: 1.5rem;
			padding: 2.5rem;
		}

		.services {
			grid-template-columns: repeat(2, 1fr);
			gap: 3rem 5rem;
		}
	}
</style>
