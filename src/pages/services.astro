---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import ContactCTA from '../components/ContactCTA.astro';
import type { iconPaths } from '../components/IconPaths';

const services: { icon: keyof typeof iconPaths; title: string; body: string }[] = [
	{ icon: 'code', title: 'Développement Unity', body: 'De l\'idée au produit livré : je conçois et développe vos applications et jeux sous Unity — mobile, desktop et WebGL — avec une vraie exigence de qualité et un code pensé pour durer.' },
	{ icon: 'mobile', title: 'Application mobile', body: 'Vos applications iOS et Android développées sous Unity, jusqu\'à la publication sur les stores : interfaces soignées, bonnes performances et accès aux fonctions natives (capteurs, notifications, mode hors-ligne).' },
	{ icon: 'virtual-reality', title: 'Réalité virtuelle / XR', body: 'Des expériences immersives VR/XR pour la formation, la simulation ou le jeu, sur casque comme sur mobile : interaction naturelle, confort d\'usage et rendu optimisé.' },
	{ icon: 'strategy', title: 'Multijoueur Unity', body: 'Du temps réel qui tient la route : synchronisation, netcode, serveurs headless. Une architecture réseau solide pour vos jeux et applications, du prototype à la production.' },
	{ icon: 'scales', title: 'Audit & reprise de projet Unity', body: 'Vous héritez d\'un projet Unity ? J\'en fais l\'audit, corrige les bugs, optimise les performances et les temps de chargement et gère la montée de version — pour sécuriser votre base de code et la remettre en mouvement.' },
];

// Interventions concrètes, plus fines que les 5 prestations ci-dessus.
const capabilities: string[] = [
	'Suivi d\'alternants et de jeunes développeurs',
	'Formation à Unity et au C#',
	'Conseils pour bien structurer un projet Unity',
	'Résolution de problèmes techniques complexes',
	'Optimisation des performances, de la mémoire et de la taille du build',
	'Intégration d\'AssetBundles et d\'Addressables',
	'Développement de gameplays sur-mesure',
	'Mise en œuvre du moteur physique',
	'Multijoueur avec Photon ou Netcode',
	'Interfaces et menus in-game (UI)',
	'Sons et musiques avec réglages de volume',
	'Localisation multilingue des textes',
	'Outils internes sur-mesure, affinés au fil des projets',
	'Cheat codes de debug pour accélérer les tests',
];

const title = 'Services — Développement Unity, mobile, VR & multijoueur | Ludiven Studio';
const description = 'Prestations de développement Unity : applications mobiles, jeux, expériences VR/XR et multijoueur temps réel, de la conception à la mise en production. Développeur Unity depuis 2010, en France et à distance.';

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'ProfessionalService',
	name: 'Ludiven Studio',
	url: 'https://www.ludiven-studio.fr/services/',
	description,
	areaServed: { '@type': 'Country', name: 'France' },
	provider: { '@type': 'Organization', name: 'Ludiven Studio', url: 'https://www.ludiven-studio.fr/' },
	serviceType: [...services.map((s) => s.title), ...capabilities],
};
---

<BaseLayout title={title} description={description}>
	<div class="stack gap-20">
		<main class="wrapper stack gap-12">
			<Hero
				title="Services"
				tagline="Développeur Unity depuis 2010, je vous accompagne de la conception à la mise en production : applications, jeux et expériences immersives — en France comme à distance."
				align="start"
			/>

			<section class="box services">
				{services.map((s) => (
					<div class="stack gap-2 lg:gap-4">
						<Icon icon={s.icon} color="var(--accent-regular)" size="2.5rem" gradient />
						<h2>{s.title}</h2>
						<p>{s.body}</p>
					</div>
				))}
			</section>

			<section class="stack gap-6">
				<h2 class="section-title">Interventions & compétences</h2>
				<ul class="capabilities">
					{capabilities.map((c) => (
						<li class="cap">
							<Icon icon="check" color="var(--accent-regular)" size="1.15rem" />
							<span>{c}</span>
						</li>
					))}
				</ul>
			</section>
		</main>

		<ContactCTA />
	</div>

	<script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
</BaseLayout>

<style>
	.box {
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		padding: 1.5rem;
		background-color: var(--gray-999_40);
		box-shadow: var(--shadow-sm);
	}

	.services {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}

	.services h2 {
		font-size: var(--text-lg);
	}

	.services p {
		color: var(--gray-400);
	}

	.section-title {
		font-size: var(--text-2xl);
	}

	.capabilities {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.75rem;
	}

	.cap {
		display: flex;
		align-items: flex-start;
		gap: 0.6rem;
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		padding: 0.8rem 1rem;
		background-color: var(--gray-999_40);
	}

	.cap :global(svg) {
		flex: none;
		margin-top: 0.15rem;
	}

	.cap span {
		color: var(--gray-300);
		font-size: var(--text-sm);
		line-height: 1.45;
	}

	@media (min-width: 50em) {
		.box {
			border-radius: 1.5rem;
			padding: 2.5rem;
		}

		.services {
			display: grid;
			grid-template-columns: repeat(2, 1fr);
			gap: 3rem 5rem;
		}

		.services h2 {
			font-size: var(--text-2xl);
		}

		.section-title {
			font-size: var(--text-3xl);
		}

		.capabilities {
			grid-template-columns: repeat(2, 1fr);
			gap: 0.75rem 1.5rem;
		}
	}
</style>
