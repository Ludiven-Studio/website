---
import BaseLayout from '../layouts/BaseLayout.astro';

import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout title="À propos | Ludiven Studio" description="Découvrez Ludiven Studio, notre vision et nos valeurs">
	<div class="stack gap-20">
		<main class="wrapper about">
			<Hero
				title="À propos"
				tagline="Ludiven Studio, un studio qui joint l'utile à l'agréable pour des projets qui font avancer les choses"
			>
				<img
					width="1553"
					height="873"
					src="/assets/code-fx.jpg"
					alt="Ludiven Studio"
				/>
			</Hero>

			<section>
				<h2 class="section-title">Notre vision</h2>
				<div class="content">
					<p>
						Ludiven Studio est un studio de développement dédié à la création d'applications,
						de jeux et d'expériences numériques. Notre ambition&nbsp;: concevoir des projets
						qui allient sérieux et plaisir, et qui apportent une vraie valeur à celles et ceux qui les utilisent.
					</p>
					<br>
					<p>
						Que ce soit pour vous accompagner dans la réalisation d'un projet, inventer un nouveau gameplay,
						ou construire un outil qui rend un sujet complexe plus accessible, nous mettons le soin du détail
						et la rigueur technique au service de vos idées.
					</p>
				</div>
			</section>

			<section>
				<h2 class="section-title">Nos centres d'intérêt</h2>
				<div class="content">
					<table>
						<tr>
							<th>Accompagnement</th>
							<th>Vous guider dans la réalisation de vos applications et projets numériques</th>
						</tr>
						<tr>
							<th>Ludo-éducatif</th>
							<th>Allier le divertissement et l'apprentissage de façon ludique</th>
						</tr>
						<tr>
							<th>Gameplay</th>
							<th>Faire découvrir de nouveaux gameplay et le plaisir de s'amuser</th>
						</tr>
						<tr>
							<th>Utile & agréable</th>
							<th>Concevoir des projets sérieux qui font avancer les choses</th>
						</tr>
					</table>
				</div>
			</section>

			<section>
				<h2 class="section-title">Expertises</h2>
				<div class="content">
					<table>
						<tr>
							<th>Plateformes</th>
							<th>PC, Mac, Android, iPhone, Web, Casques VR, Consoles</th>
						</tr>
						<tr>
							<th>Technologies</th>
							<th>Unity 3D, C#, C/C++, PHP, Symfony, API Platform, Java, JavaScript, SQL, HLSL</th>
						</tr>
						<tr>
							<th>Domaines</th>
							<th>Jeux-vidéos, applications mobiles, réalité virtuelle, jumeaux numériques, objets connectés</th>
						</tr>
						<tr>
							<th>Méthodes</th>
							<th>Approche Agile / Scrum, intégration continue, tests, versionning</th>
						</tr>
					</table>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.about {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
	}

	img {
		margin-top: 1.5rem;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
		width: 100%;
		aspect-ratio: 1553 / 680;
		object-fit: cover;
		object-position: top;
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		color: var(--gray-200);
	}

	.section-title {
		grid-column-start: 1;
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	.content {
		grid-column: 2 / 4;
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.about {
			display: grid;
			grid-template-columns: 1fr 60% 1fr;
		}

		.about > :global(:first-child) {
			grid-column-start: 2;
		}

		section {
			display: contents;
			font-size: var(--text-lg);
		}
	}
</style>
